NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=
ENABLE_SCORING_INSPECTOR=
# H1 nflverse history import (npm run import:nflverse-history, validate:nflverse-history)
# Requires NEXT_PUBLIC_SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY above.
# No additional env vars needed — nflverse data is public.

# F4 live scoring validation runner (npm run validate:scoring-live)
# Set to the Supabase auth user ID whose leagues you want to validate.
# Never commit a real user ID here.
SCORING_VALIDATION_OPERATOR_USER_ID=
