{
  "name": "blackbird-gm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "smoke:provider-pipeline": "vitest run --config vitest.smoke.config.ts scripts/provider-pipeline-smoke.smoke.ts",
    "smoke:provider-import": "vitest run --config vitest.smoke.config.ts scripts/provider-import-smoke.smoke.ts",
    "validate:scoring-live": "vitest run --config vitest.smoke.config.ts scripts/scoring-validation-live.smoke.ts",
    "import:nflverse-history": "tsx scripts/nflverse-history-import.ts",
    "smoke:nflverse-history-import": "vitest run --config vitest.smoke.config.ts scripts/nflverse-history-import.smoke.ts",
    "validate:nflverse-history": "vitest run --config vitest.smoke.config.ts scripts/nflverse-history-validate.smoke.ts",
    "diagnose:nflverse-history": "tsx scripts/nflverse-history-diagnose.ts",
    "smoke:nflverse-history-resume": "vitest run --config vitest.smoke.config.ts scripts/nflverse-history-resume.smoke.ts",
    "bootstrap:gsis-identities": "tsx scripts/gsis-identity-bootstrap.ts",
    "validate:gsis-identities": "tsx scripts/gsis-identity-validate.ts",
    "diagnostic:gsis": "tsx scripts/gsis-diagnostic.ts",
    "diagnose:2025-identities": "tsx scripts/diagnose-2025-identities.ts",
    "repair:sleeper-player-identities": "tsx scripts/repair-sleeper-player-identities.ts",
    "test:watch": "vitest",
    "generate:types": "node scripts/ensure-typegen-dir.mjs && next typegen",
    "verify": "npm test && npm run lint && npm run build && npm run typecheck",
    "typecheck": "npm run generate:types && tsc --noEmit",
    "clean:typecheck": "node scripts/clean-typecheck.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.4",
    "lucide-react": "^0.468.0",
    "next": "^15.1.3",
    "papaparse": "^5.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
