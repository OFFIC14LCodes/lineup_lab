{
  "name": "blackbird-gm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "smoke:provider-pipeline": "vitest run --config vitest.smoke.config.ts",
    "test:watch": "vitest",
    "generate:types": "node scripts/ensure-typegen-dir.mjs && next typegen",
    "verify": "npm test && npm run lint && npm run build && npm run typecheck",
    "typecheck": "npm run generate:types && tsc --noEmit",
    "clean:typecheck": "node scripts/clean-typecheck.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.4",
    "lucide-react": "^0.468.0",
    "next": "^15.1.3",
    "papaparse": "^5.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
